{
  "expo": {
    "name": "SafeBuddy",
    "slug": "safe-buddy",
    "version": "1.0.0",
    "icon": "./assets/Character/buddy-happy.png",
    "scheme": "safebuddy",
    "userInterfaceStyle": "automatic",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Character/buddy-happy.png",
        "backgroundColor": "#F7F6F2"
      },
      "splash": {
        "image": "./assets/Character/buddy-happy.png",
        "backgroundColor": "#F7F6F2",
        "resizeMode": "contain",
        "imageWidth": 200
      },
      "package": "com.slaff.safebuddy"
    },
    "ios": {
      "icon": "./assets/Character/buddy-happy.png",
      "supportsTablet": true,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.slaff.safebuddy",
      "splash": {
        "image": "./assets/Character/buddy-happy.png",
        "backgroundColor": "#F7F6F2",
        "resizeMode": "contain",
        "imageWidth": 200
      },
      "bundleIdentifier": "com.slaff.safebuddy"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "splash": {
      "image": "./assets/Character/buddy-happy.png",
      "backgroundColor": "#F7F6F2",
      "resizeMode": "contain",
      "imageWidth": 200
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "aed5fa10-e8e4-451a-8bed-3371c14235a5"
      }
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/78ab1b33-4629-4e73-9213-6a89efe7baae"
    },
    "owner": "slaff"
  }
}
