{
  "expo": {
    "name": "RealoKids",
    "slug": "realokids",
    "version": "1.0.2",
    "icon": "./assets/Character/buddy-happy.png",
    "scheme": "realokids",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Character/buddy-happy.png",
        "backgroundColor": "#F7F6F2"
      },
      "package": "com.slaff.realokids",
      "permissions": ["android.permission.MODIFY_AUDIO_SETTINGS"]
    },
    "ios": {
      "icon": "./assets/Character/buddy-happy.png",
      "supportsTablet": true,
      "requireFullScreen": true,
      "bundleIdentifier": "com.slaff.realokids",
      "buildNumber": "1"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/Character/buddy-happy.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1D6B4F",
          "dark": {
            "backgroundColor": "#1D6B4F"
          }
        }
      ],
      [
        "expo-audio",
        {
          "recordAudioAndroid": false
        }
      ],
      "expo-font",
      "expo-localization",
      "expo-web-browser",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "RealoKids lets parents choose pictures for schedule, routine, and mission items."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d8ca8d09-35ff-4f03-a069-471bcba052f9"
      }
    },
    "runtimeVersion": "1.0.2",
    "owner": "slaff"
  }
}
