{
  "expo": {
    "name": "RealoKids",
    "slug": "realokids",
    "version": "1.0.0",
    "icon": "./assets/Character/buddy-happy.png",
    "scheme": "realokids",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/Character/buddy-happy.png",
        "backgroundColor": "#F7F6F2"
      },
      "package": "com.slaff.realokids",
      "versionCode": 1
    },
    "ios": {
      "icon": "./assets/Character/buddy-happy.png",
      "supportsTablet": true,
      "requireFullScreen": true,
      "bundleIdentifier": "com.slaff.realokids",
      "buildNumber": "1"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/Character/buddy-happy.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F7F6F2",
          "dark": {
            "backgroundColor": "#F7F6F2"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {}
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "owner": "slaff"
  }
}
